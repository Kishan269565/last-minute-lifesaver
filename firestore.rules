rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    match /tasks/{taskId} {
      allow read, write: if true;
    }

    match /habits/{habitId} {
      allow read, write: if true;
    }
  }
}
